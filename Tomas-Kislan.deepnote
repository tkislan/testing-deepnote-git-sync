          contentHash: aa22d572
          executionCount: 1
          executionFinishedAt: 2025-12-23T07:52:16.386Z
          executionStartedAt: 2025-12-23T07:52:14.239Z
          type: sql
          content: >2-
                  WITH
                    T AS (
                      SELECT
                        TABLES.table_schema AS table_schema,
                        TABLES.table_name AS table_name,
                        regexp_extract(TABLES.table_name, '^(.*)\\d{8}$') AS shard_prefix
                      FROM INFORMATION_SCHEMA.TABLES AS TABLES
                      WHERE TABLES.table_type IN ('BASE TABLE', 'VIEW', 'MATERIALIZED VIEW')
                    )
                  SELECT
                    table_schema,
                    COALESCE(shard_prefix, table_name) AS table_name,
                    ARRAY_AGG(CASE WHEN shard_prefix IS NOT NULL THEN table_name END IGNORE NULLS)
                      AS shard_table_names
                  FROM T
                  GROUP BY table_schema, table_name;
          metadata:
            execution_start: 1766476334239
            execution_millis: 2147
            execution_context_id: d9fbf24e-3069-4165-b71e-ec63f933b1be
