          sortingKey: "000000"
          contentHash: f678b0fb
          executionCount: 4
          executionFinishedAt: 2025-12-30T09:38:09.606Z
          executionStartedAt: 2025-12-30T09:38:05.099Z
          type: sql
          content: >-
            -- Average number of notebooks per project by plan

            with t as (select count(*) as cnt, n.project_id, ap.plan_name

            from deepnote_production_view.notebooks n

            left join deepnote_production_view.projects p on n.project_id = p.id

            left join deepnote_production_view.teams t on p.team_id = t.id

            left join deepnote_production_view.active_plans ap on ap.team_id = t.id

            group by n.project_id, ap.plan_name)

            select avg(cnt), plan_name from t

            group by plan_name

            ;
          metadata:
            execution_start: 1767087485099
            execution_millis: 4507
            execution_context_id: 0a39fe72-a72c-450b-b3a6-e992b4b08194
            deepnote_table_state:
