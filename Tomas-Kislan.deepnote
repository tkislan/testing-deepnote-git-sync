          executionFinishedAt: 2025-11-22T09:21:32.673Z
          executionStartedAt: 2025-11-22T09:21:29.945Z
          type: sql
          content: >-
            -- Number of users per team per role in DAZN workspaces

            select t.name, t.slug, tm.user_role, count(*) as cnt from deepnote_production_view.teams t

            left join deepnote_production_view.team_members tm on t.id = tm.team_id

            left join deepnote_production_view.users u on tm.user_id = u.id

            where lower(t.name) like '%dazn%'

            group by t.id, t.name, t.slug, tm.user_role

            having cnt >= 5

            order by t.slug, tm.user_role
          metadata:
