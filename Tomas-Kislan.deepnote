        - id: 19f9cd4b31384f71a000347585dc1483
          blockGroup: 9810a727591f42d6bcb3469129a938f3
          sortingKey: "000008"
          contentHash: 79f544d3
          executionCount: 4
          executionFinishedAt: 2025-11-22T09:21:35.313Z
          executionStartedAt: 2025-11-22T09:21:32.735Z
          type: sql
          content: >-
            -- Number of projects with activity in the last 90 days

            with t as (SELECT max(b.updated_at) as max_udpated_at, project_id 

            FROM `deepnote_production_view.blocks` b

            left join deepnote_production_view.notebooks n on b.notebook_id = n.id

            GROUP BY project_id

            HAVING max_udpated_at > TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 90 DAY)

            )

            select count(*) from t
          metadata:
            execution_start: 1763803292735
            execution_millis: 2578
            execution_context_id: a700e648-4d0d-4a0b-b238-7fb6f491a0ba
            deepnote_variable_name: query_4
            deepnote_return_variable_type: query_preview
            sql_integration_id: c965a743-58bd-47ad-b24f-d8327932f9ef
